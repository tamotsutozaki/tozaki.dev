# Copie para .env.local e preencha. Nenhum destes é obrigatório para rodar o stub.

# Formulário de contato (Resend) — usado pela Cloudflare Pages Function
# em functions/api/contact.ts. No Cloudflare: Settings → Variables and Secrets.
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=pedro@tozaki.dev
# from: comece com onboarding@resend.dev (sem verificar domínio). Depois de
# verificar tozaki.dev na Resend, troque por algo como site@tozaki.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Links públicos (opcional — há defaults em lib/site.ts)
NEXT_PUBLIC_CAL_LINK=https://cal.com/seu-usuario
NEXT_PUBLIC_WHATSAPP=https://wa.me/55SEUNUMERO
